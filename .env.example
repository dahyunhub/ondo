# docker-compose 시크릿. 복사해서 .env 로 채운다(.env 는 .gitignore 로 커밋 금지).
#   cp .env.example .env
# 운영(prod)은 반드시 아래 값을 강한 시크릿으로 교체.

# MySQL 계정
DB_USERNAME=ondo
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# JWT 서명 키 (HS256 → 최소 32바이트)
JWT_SECRET=change-me-to-a-strong-secret-at-least-32-bytes

# 활성 프로파일 (dev: 시드 교사 생성 → 로그인 데모 / prod: 시드 없음, 회원가입으로 시작)
SPRING_PROFILES_ACTIVE=prod

# 외부 LLM(OpenAI) — 미설정 시 일반 화면은 정상, AI 일지·평가만 비활성.
AI_API_KEY=
AI_MODEL=gpt-5.4-mini

# 외부 노출 포트 — web(nginx)가 SPA + /api 프록시. app 직접 포트는 디버그용.
WEB_PORT=80
APP_PORT=8090
